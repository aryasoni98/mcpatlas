{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CNCF MCP Helm values",
  "description": "Schema for mcp-atlas chart values (Helm 3)",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string", "description": "Override chart name" },
    "fullnameOverride": { "type": "string", "description": "Override full resource names" },
    "replicaCount": { "type": "integer", "minimum": 0, "default": 1, "description": "Number of replicas" },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "default": "ghcr.io/mcp-atlas/server" },
        "tag": { "type": "string", "default": "latest" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"], "default": "IfNotPresent" }
      }
    },
    "transport": { "type": "string", "enum": ["stdio", "sse"], "default": "sse" },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 3000 },
    "rateLimit": { "type": "integer", "minimum": 0, "default": 50 },
    "skipGithub": { "type": "boolean", "default": true },
    "cache": {
      "type": "object",
      "properties": {
        "maxAge": { "type": "integer", "minimum": 0, "default": 86400 }
      }
    },
    "github": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "secretName": { "type": "string" },
        "secretKey": { "type": "string", "default": "token" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "minAvailable": { "type": "integer", "minimum": 0 }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      },
      "description": "Recommended: requests 100m–500m CPU, 256Mi–512Mi memory; limits 512Mi memory for 2.4k projects"
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true },
        "automount": { "type": "boolean", "default": true },
        "name": { "type": "string" }
      }
    }
  }
}
